{
  "name": "unidrive-backend",
  "version": "1.0.0",
  "description": "UNIDrive – RESTful API za sustav suprijevoza i dijeljenja prijevoza studenata Sveučilišta u Dubrovniku (Node.js + Express.js + MySQL).",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "start:prod": "cross-env NODE_ENV=production node src/server.js",
    "dev": "nodemon src/server.js",
    "db:migrate": "node src/db/migrate.js",
    "db:seed": "node src/db/migrate.js --seed",
    "test": "cross-env NODE_ENV=test jest --runInBand"
  },
  "keywords": [
    "carpooling",
    "suprijevoz",
    "express",
    "mysql",
    "rest-api",
    "unidrive"
  ],
  "author": "UNIDrive tim (Antonio Butijer, Daniel Miletić, Tomislav Matić)",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.11.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
